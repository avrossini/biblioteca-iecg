# Supabase local — os valores são impressos ao rodar `npx supabase start`.
# A partir do contêiner do app, o Supabase é alcançado via host.docker.internal.
NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Somente no servidor / scripts de migração — NUNCA expor no cliente:
SUPABASE_SERVICE_ROLE_KEY=

# Conexão direta ao Postgres local (scripts de migração/ETL):
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres
