# Supabase local — os valores são impressos ao rodar `npx supabase start`.
# 127.0.0.1 funciona para o app rodando no host (npm run dev) e para o navegador.
# (O docker-compose sobrescreve para host.docker.internal dentro do contêiner.)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Somente no servidor / scripts de migração — NUNCA expor no cliente:
SUPABASE_SERVICE_ROLE_KEY=

# Conexão direta ao Postgres local (scripts de migração/ETL):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Regras de negócio configuráveis
# Prazo padrão de devolução de empréstimos, em dias (default 14):
NEXT_PUBLIC_PRAZO_DEVOLUCAO_DIAS=14

# ===== Migração de dados (Fase 8) — só para o ETL local =====
# Caminho do dump MySQL do legado no host (montado no container mysql-legacy).
# Aspas se o caminho tiver espaços/acentos. Ex.: Windows/OneDrive:
LEGACY_DUMP_PATH="C:/Users/rossi/OneDrive/Área de Trabalho/iecg/iecg.sql"
# Conexão ao MySQL efêmero (docker compose --profile legacy up -d mysql-legacy):
LEGACY_MYSQL_URL=mysql://root:root@127.0.0.1:3307/forge

# ===== Produção (Fase 9) — NÃO commitar valores reais; ficam na Vercel/segredos =====
# App na Vercel (runtime): NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon>  SUPABASE_SERVICE_ROLE_KEY=<service_role, server-only>
# ETL/bootstrap contra o Cloud (exige TLS → sslmode=require):
#   MIGRACAO_PERMITIR_REMOTO=1
#   DATABASE_URL=postgresql://postgres:<senha>@db.<ref>.supabase.co:5432/postgres?sslmode=require
#   (fallback session pooler: postgresql://postgres.<ref>:<senha>@aws-0-sa-east-1.pooler.supabase.com:5432/postgres)
# Bootstrap do admin: ADMIN_EMAIL=... ADMIN_PASSWORD=...
# CLIs (uso pontual): SUPABASE_ACCESS_TOKEN=...  VERCEL_TOKEN=...
